# 复制为 .env 或写入系统环境变量（勿提交 .env 到 Git）
# 本地运行时配置也可写在 data/ly_next/config.yaml（data/ 已在 .gitignore）

# 工作台 API Key
LY_NEXT_API_KEY=

# Telegram Bot（@BotFather）
TELEGRAM_BOT_TOKEN=

# NapCat / OneBot WebSocket Token（与 NapCat 客户端一致，可留空）
ONEBOT11_ACCESS_TOKEN=

# 数据库（可选）
POSTGRES_PASSWORD=
REDIS_PASSWORD=
