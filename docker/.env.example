# 复制为同目录下的 .env 后修改（Compose 会从本编排文件所在目录加载 .env 做变量替换）
#
# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ly_next
# 若本机已占用 5432，可改为例如 5433:5432 的左侧端口
POSTGRES_PUBLISH=5432

# Redis
REDIS_PUBLISH=6379
REDIS_PASSWORD=

# 应用（--profile app）
LY_NEXT_PORT=8000
LY_NEXT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
