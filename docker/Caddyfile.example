# LY-NEXT 反向代理示例（Caddy 自动 HTTPS）
# 用法：复制为 Caddyfile，将 your-domain.com 改为你的域名，然后：
#   caddy run --config Caddyfile
#
# 应用仅监听内网（docker-compose 中 app 不直接 publish 8000 时）：
#   reverse_proxy ly-next-app:8000

your-domain.com {
    encode gzip

    reverse_proxy 127.0.0.1:8000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote_host}
    }
}

# 启用后请在 data/ly_next/config.yaml 设置：
#   auth.cookie_secure: true
#   security.rate_limit.trust_proxy_headers: true
